### Shared config ###
include ~/.config/wm/config

### Environment ###
# Nvidia + scaling env vars are in ~/.config/environment.d/sway-nvidia.conf
# (sourced by systemd for graphical sessions via SDDM)

# Export to systemd/dbus for child processes (portals, etc.)
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

### Monitors ###
# DP-1 center, HDMI-A-1 right, HDMI-A-2 left
output DP-1 pos 0 0 scale 1.5
output HDMI-A-1 pos 2560 0 scale 1.5
output HDMI-A-2 pos -2560 0 scale 1.5

### Wallpaper ###
output * bg /home/xander/Documents/wallpaper/city-skyline.jpg fill

### XWayland ###
xwayland enable

### Input ###
input type:keyboard {
    xkb_layout us
    repeat_delay 200
    repeat_rate 30
}

input type:pointer {
    pointer_accel 0.2
}

input type:touchpad {
    natural_scroll disabled
}

### Autostart ###
exec waybar &
exec nm-applet &
exec pasystray &

### Sway-specific keybindings ###

# Screenshot (grim + slurp → clipboard + file)
bindsym $mod+$smod+s exec grim -g "$(slurp)" - | tee ~/Pictures/screenshots/$(date +%Y-%m-%d_%H-%M-%S).png | wl-copy

# Reload sway config
bindsym $mod+$smod+z reload
