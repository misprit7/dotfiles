### Variables ###
set $mod Mod1
set $smod Shift
set $terminal kitty
set $browser firefox
set $menu fuzzel

### Look and Feel ###

# Gaps
gaps inner 5
gaps outer 20

# Borders
default_border pixel 2
default_floating_border pixel 2

# Colors (cyan/green active, gray inactive)
# class                 border  bg      text    indicator child_border
client.focused          #33ccff #33ccff #ffffff #00ff99   #33ccff
client.focused_inactive #595959 #595959 #ffffff #595959   #595959
client.unfocused        #595959 #303030 #888888 #595959   #595959
client.urgent           #ff5555 #ff5555 #ffffff #ff5555   #ff5555

# Font for title bars (hidden with pixel borders, but needed for i3bar fallback)
font pango:JetBrainsMono Nerd Font 10

# Floating modifier
floating_modifier $mod

# Focus follows mouse
focus_follows_mouse yes

# No focus wrapping
focus_wrapping no

### Keybindings ###

# Applications
bindsym $mod+Return exec $terminal
bindsym $mod+$smod+Return exec $browser
bindsym $mod+d exec $menu

# Window management
bindsym $mod+$smod+c kill
bindsym $mod+$smod+f floating toggle
bindsym $mod+f fullscreen toggle
bindsym $mod+m layout toggle all
bindsym $mod+s layout toggle split
bindsym $mod+c split horizontal
bindsym $mod+v split vertical

# Focus (hjkl)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move windows (hjkl)
bindsym $mod+$smod+h move left
bindsym $mod+$smod+j move down
bindsym $mod+$smod+k move up
bindsym $mod+$smod+l move right

# Parent/child focus
bindsym $mod+a focus parent
bindsym $mod+b focus child

# Cycle workspaces on current monitor (alphabetical order)
bindsym $mod+n exec ~/.config/sway/bin/cycle-workspace next
bindsym $mod+p exec ~/.config/sway/bin/cycle-workspace prev

# Rename current workspace
bindsym $mod+comma exec ~/.config/sway/bin/rename-workspace

# Open next unused workspace on current monitor
bindsym $mod+t exec ~/.config/sway/bin/open-workspace

# Swap workspace position with neighbor
bindsym $mod+$smod+n exec ~/.config/sway/bin/swap-workspace next
bindsym $mod+$smod+p exec ~/.config/sway/bin/swap-workspace prev

# Resize mode
mode "resize" {
	bindsym h resize shrink width 10 px or 10 ppt
	bindsym j resize grow height 10 px or 10 ppt
	bindsym k resize shrink height 10 px or 10 ppt
	bindsym l resize grow width 10 px or 10 ppt

	bindsym $smod+h gaps horizontal minus 5
	bindsym $smod+j gaps horizontal plus 5
	bindsym $smod+k gaps vertical minus 5
	bindsym $smod+l gaps vertical plus 5

	bindsym Return mode "default"
	bindsym Escape mode "default"
	bindsym $mod+r mode "default"
}

bindsym $mod+z mode "resize"

# Workspaces — context-aware: switches to Nth workspace on current monitor
bindsym $mod+1 exec ~/.config/sway/bin/switch-workspace 1
bindsym $mod+2 exec ~/.config/sway/bin/switch-workspace 2
bindsym $mod+3 exec ~/.config/sway/bin/switch-workspace 3
bindsym $mod+4 exec ~/.config/sway/bin/switch-workspace 4
bindsym $mod+5 exec ~/.config/sway/bin/switch-workspace 5
bindsym $mod+6 exec ~/.config/sway/bin/switch-workspace 6
bindsym $mod+7 exec ~/.config/sway/bin/switch-workspace 7
bindsym $mod+8 exec ~/.config/sway/bin/switch-workspace 8
bindsym $mod+9 exec ~/.config/sway/bin/switch-workspace 9
bindsym $mod+0 exec ~/.config/sway/bin/switch-workspace 10

# Move to workspace on current monitor
bindsym $mod+$smod+1 exec ~/.config/sway/bin/move-to-workspace 1
bindsym $mod+$smod+2 exec ~/.config/sway/bin/move-to-workspace 2
bindsym $mod+$smod+3 exec ~/.config/sway/bin/move-to-workspace 3
bindsym $mod+$smod+4 exec ~/.config/sway/bin/move-to-workspace 4
bindsym $mod+$smod+5 exec ~/.config/sway/bin/move-to-workspace 5
bindsym $mod+$smod+6 exec ~/.config/sway/bin/move-to-workspace 6
bindsym $mod+$smod+7 exec ~/.config/sway/bin/move-to-workspace 7
bindsym $mod+$smod+8 exec ~/.config/sway/bin/move-to-workspace 8
bindsym $mod+$smod+9 exec ~/.config/sway/bin/move-to-workspace 9
bindsym $mod+$smod+0 exec ~/.config/sway/bin/move-to-workspace 10

# Lock
bindsym Control+Mod1+l exec swaylock

# Mouse bindings
bindsym $mod+button4 exec ~/.config/sway/bin/cycle-workspace prev
bindsym $mod+button5 exec ~/.config/sway/bin/cycle-workspace next

# Multimedia keys
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +1000
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -1000
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl s 10%+
bindsym XF86MonBrightnessDown exec brightnessctl s 10%-
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPause exec playerctl play-pause
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioPrev exec playerctl previous

### Window Rules ###
for_window [class="zoom"] floating enable
