#!/usr/bin/env bash
# Swap the current workspace with its neighbor among used workspaces on the
# same output. Wraps around at the edges.
# Preserves custom labels but swaps the prefix (e.g. L2: work <-> L3: code
# becomes L2: code <-> L3: work).
# Usage: swap-workspace prev|next
set -euo pipefail

direction="${1:?Usage: swap-workspace prev|next}"

ws_json=$(swaymsg -t get_workspaces)

current=$(echo "$ws_json" | jq -r '.[] | select(.focused) | .name')
current_output=$(echo "$ws_json" | jq -r '.[] | select(.focused) | .output')

# Get sorted list of used workspaces on this output
mapfile -t used < <(echo "$ws_json" | jq -r --arg out "$current_output" \
    '[.[] | select(.output == $out) | .name] | sort | .[]')

count=${#used[@]}
if (( count < 2 )); then
    exit 0
fi

# Find our index
idx=-1
for i in "${!used[@]}"; do
    if [[ "${used[$i]}" == "$current" ]]; then
        idx=$i
        break
    fi
done

# Determine target index with wrapping
if [[ "$direction" == "prev" ]]; then
    target_idx=$(( (idx - 1 + count) % count ))
else
    target_idx=$(( (idx + 1) % count ))
fi

target="${used[$target_idx]}"

# Extract prefixes (e.g. "L2") and labels (e.g. ": work" or "")
current_prefix="${current%%:*}"
current_label="${current#"$current_prefix"}"
target_prefix="${target%%:*}"
target_label="${target#"$target_prefix"}"

# Build new names: swap the prefixes, keep each workspace's label
new_current="${target_prefix}${current_label}"
new_target="${current_prefix}${target_label}"

# Rename via tmp to swap
swaymsg "rename workspace \"$current\" to _swap_tmp"
swaymsg "rename workspace \"$target\" to \"$new_target\""
swaymsg "rename workspace _swap_tmp to \"$new_current\""

# Follow our windows
swaymsg "workspace \"$new_current\""
